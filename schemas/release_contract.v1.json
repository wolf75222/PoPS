{
  "release_contract_schema_version": 1,
  "public_api_version": 1,
  "semantic_ir_version": 1,
  "normalization_version": 1,
  "component_catalog_schema_version": 1,
  "component_manifest_schema_version": 2,
  "component_registry_version": 2,
  "capability_vocabulary_version": 1,
  "native_abi_version": 3,
  "checkpoint_envelope_schema_version": 1,
  "uniform_checkpoint_payload_version": 3,
  "amr_checkpoint_payload_version": 3,
  "supported_matrix": {
    "language": {
      "python": ["3.12"],
      "cpp_standard": 20,
      "compiler_families": ["GNU", "AppleClang"]
    },
    "kokkos": {
      "version": "4.4.01",
      "execution_spaces": ["Serial", "OpenMP"]
    },
    "distributed": {
      "mpi_implementation": "OpenMPI",
      "execution_spaces": ["Serial"]
    },
    "source_builds": [
      {"os": "linux", "arch": "x86_64", "backend": "Kokkos Serial"},
      {"os": "linux", "arch": "x86_64", "backend": "Kokkos OpenMP"},
      {"os": "linux", "arch": "x86_64", "backend": "Kokkos Serial + OpenMPI"},
      {"os": "macos", "arch": "arm64", "backend": "Kokkos Serial"}
    ],
    "wheels": [
      {"os": "macos", "arch": "arm64", "python": "cp312", "backend": "Kokkos Serial"}
    ],
    "not_promised": ["CUDA wheel", "HIP wheel", "MPI wheel", "Windows wheel"]
  }
}
